<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Smart Repair Tracker</title>

  <style>
    body { font-family: Arial, sans-serif; background: #f5f5f5; padding: 20px; }
    .container { max-width: 900px; margin: auto; }
    h1 { text-align: center; margin-bottom: 30px; }

    .tiles {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
      margin-bottom: 40px;
    }

    .tile {
      background: white;
      padding: 25px;
      border-radius: 10px;
      text-align: center;
      box-shadow: 0 0 10px rgba(0,0,0,0.1);
      cursor: pointer;
      transition: 0.2s;
    }

    .tile:hover {
      transform: scale(1.03);
      background: #eef6ff;
    }

    .stats {
      background: white;
      padding: 20px;
      border-radius: 10px;
      box-shadow: 0 0 10px rgba(0,0,0,0.1);
      margin-bottom: 30px;
    }

    .recent-jobs {
      background: white;
      padding: 20px;
      border-radius: 10px;
      box-shadow: 0 0 10px rgba(0,0,0,0.1);
    }
  </style>
</head>

<body>
<%- include('../partials/nav') %>

<div class="container">
  <h1>Smart Repair Tracker</h1>

  <!-- Quick Tiles -->
  <div class="tiles">
    <a href="/jobs" class="tile">View Jobs</a>
    <a href="/jobs/new" class="tile">Book New Job</a>
    <a href="/customers" class="tile">Customers</a>
    <a href="/customers/new" class="tile">Add Customer</a>
    <a href="/technicians" class="tile">Technicians</a>
    <a href="/technicians/new" class="tile">Add Technician</a>
  </div>

  <!-- Stats -->
  <div class="stats">
    <h3>Today's Overview</h3>
    <p>Jobs booked today: <strong id="jobsToday">0</strong></p>
    <p>Jobs in progress: <strong id="jobsProgress">0</strong></p>
    <p>Completed today: <strong id="jobsCompleted">0</strong></p>
  </div>

  <!-- Recent Jobs -->
  <div class="recent-jobs">
    <h3>Recent Jobs</h3>
    <ul id="recentJobs"></ul>
  </div>
</div>

<script>
async function loadStats() {
  const res = await fetch("/api/jobs");
  const jobs = await res.json();

  const today = new Date().toISOString().slice(0, 10);

  document.getElementById("jobsToday").textContent =
    jobs.filter(j => j.created_at?.startsWith(today)).length;

  document.getElementById("jobsProgress").textContent =
    jobs.filter(j => j.status === "in_progress").length;

  document.getElementById("jobsCompleted").textContent =
    jobs.filter(j => j.status === "completed" && j.updated_at?.startsWith(today)).length;

  const recent = jobs.slice(0, 5);
  const list = document.getElementById("recentJobs");

  recent.forEach(j => {
    const li = document.createElement("li");
    li.textContent = `${j.job_number} — ${j.item_type} (${j.status})`;
    list.appendChild(li);
  });
}

loadStats();
</script>

</body>
</html>
