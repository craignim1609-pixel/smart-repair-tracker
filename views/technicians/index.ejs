<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Technicians</title>

  <style>
    body { 
      font-family: Arial, sans-serif; 
      background: #f5f5f5; 
      padding: 20px; 
    }
    .container {
      max-width: 600px; 
      margin: auto; 
      background: white; 
      padding: 25px;
      border-radius: 10px; 
      box-shadow: 0 0 10px rgba(0,0,0,0.1);
    }
    h2 { 
      text-align: center; 
      margin-top: 0; 
    }
    table { 
      width: 100%; 
      border-collapse: collapse; 
      margin-top: 20px; 
    }
    th, td { 
      padding: 12px; 
      border-bottom: 1px solid #ddd; 
      text-align: left; 
    }
    th { 
      background: #0078ff; 
      color: white; 
    }
  </style>
</head>

<body>
<%- include('../partials/nav') %>

<div class="container">
  <h2>Technicians</h2>

  <table>
    <thead>
      <tr>
        <th>Name</th>
      </tr>
    </thead>

    <tbody>
      <% if (technicians && technicians.length > 0) { %>
        <% technicians.forEach(t => { %>
          <tr>
            <td><%= t.name %></td>
          </tr>
        <% }) %>
      <% } else { %>
        <tr>
          <td colspan="1" style="text-align:center; padding:20px;">
            No technicians found.
          </td>
        </tr>
      <% } %>
    </tbody>
  </table>
</div>

</body>
</html>
